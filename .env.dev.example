# Local development — copy to .env.dev (gitignored).
# Dev uses a separate systemd unit and config dir from production.

NEURALNEXUS_API_BASE_URL=http://localhost:8123
NEURALNEXUS_MCP_CONFIG_DIR=~/.config/neuralnexus-mcp-dev

# Local MCP HTTP server (production default is 8000)
PORT=9990
MCP_HOST=127.0.0.1
MCP_PATH=/mcp
MCP_SERVER_NAME=Ubuntu-OS-Filesystem-dev

# Non-interactive first-time dev setup (optional)
# NEURALNEXUS_API_KEY=sk-...
# NEURALNEXUS_WATCH_FOLDER=/path/to/test/data

# Multiple watched folders, colon-separated (overrides HEALTH_DATA_DIR)
MCP_WATCHED_ROOTS=
