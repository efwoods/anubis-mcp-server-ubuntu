# Local MCP HTTP server
PORT=8000
MCP_HOST=127.0.0.1
MCP_PATH=/mcp
MCP_SERVER_NAME=Ubuntu-OS-Filesystem

# Default watched folder when none is configured via setup
HEALTH_DATA_DIR=/home/user/Documents/Health Auto Export/health_metric_data

# Multiple watched folders, colon-separated (overrides HEALTH_DATA_DIR).
# Prefer `./neuralnexus-mcp.sh add-folder /path/to/folder` for day-to-day use.
MCP_WATCHED_ROOTS=

# NeuralNexus API (outbound relay — no Cloudflare required)
API_BASE_URL=https://api.neuralnexus.site

# Non-interactive one-click install (optional)
# NEURALNEXUS_API_KEY=sk-...
# NEURALNEXUS_WATCH_FOLDER=/path/to/data
# NEURALNEXUS_API_BASE_URL=https://api.neuralnexus.site

# Advanced: optional Cloudflare tunnel instead of relay
# NEURALNEXUS_CONNECTION_MODE=relay
# PUBLIC_BASE_URL=https://your-id.mcp.neuralnexus.site
# CLOUDFLARE_TUNNEL_TOKEN=
